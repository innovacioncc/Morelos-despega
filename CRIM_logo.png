.paginate_button {
		margin-right:5px;
		margin-left:5px;
	}
	
	.dataTables_paginate {
		margin-top: 50px;	
      	margin-bottom: 100px;
	}
	
	.paginate_button {
		cursor: pointer;
		border-color: #F18602;
		border-style: solid;
    border-width: 1px 1px 1px 1px;
		padding: 10px 17px 10px 17px;
	}
	
	.dataTables_paginate a.current {
		background: #F18602;
		color: white;
	}
	
	
	  .previous {
		cursor:pointer;
		transition: 500ms all;
		border-color: #F18602;
		border-style: solid;
    border-width: 1px 1px 1px 1px;
		padding: 10px 17px 10px 17px;
	}
	
	.previous .disabled {
		background: white;
	}
	
	.next {
		cursor:pointer;
		transition: 500ms all;
		border-color: #F18602;
		border-style: solid;
    border-width: 1px 1px 1px 1px;
		padding: 10px 17px 10px 17px;
	}
	
	.next .disabled {
		background: white;
	}


/********++***/

.dataTables_info {
 /*display: none; */
}

.admin2020_legacy_admin {
	display: none !important; 
}
#wpadminbar{
	display: none !important; 
}

/***hide admin***/
.administrator, 
.super_admin, 
.secretaria_administrativa, 
.secretaria_academica_docencia, 
.secretaria_academica_vinculacion, 
.secretaria_academica_seguimiento, 
.secretaria_tecnica_publicaciones, 
.secretaria_tecnica_biblioteca, 
.secretaria_tecnica_mailing, 
.direccion {
  display: none;
}



div#profile-page.wrap div.pp-group-box h3:first-of-type, #pp_current_user_exceptions_ui {
  display: none !important;
}

#pp_current_user_exceptions_ui{
  display: none !important;
}

/*Oculta la sección de nuevo*/
.uk-button-primary {
  display: none;
  background: white !important;
}

span.uk-button.uk-button-small.uk-border-pill.uk-button-primary {
  display: none !important;
}
.uk-navbar-nav li a .uk-button {
  display: none !important;
}
/*Oculta un elemento importante para hacer el filtro de ordenamiento*/
.hide-element-search {
  display:none;
}
/*Estilos para el listado de enlaces de los perfiles*/
.list-element-search {
  color: black !important;
  transition: 500ms all; 
}
.list-element-search:hover {
  color: #F18700 !important;
}

/*Active Alphabet*/
div.alphabet a.active, div.alphabet a.active.empty {
  color: white !important;
  border: 0 !important;
  background: #F18700 !important;
  font-size: 1.5em !important;
}


.alphabet ul li .active span {
  color: white !important;
  font-size:1em !important;
  padding: 10px !important;
}
.alphabet ul li a span {
  color: #F18700 !important;
}
.alphabet ul li .empty span {
  color: #adacac !important;
}


div.alphabet a {
color: #f18700 !important; 
}

div.alphabet a.empty {
font-size: 1.5em !important; 
}


div.alphabet a.active {
   color: #F18700 !important;
}

.column_column ul, .column_column ol, .the_content_wrapper:not(.is-elementor) ul, .the_content_wrapper:not(.is-elementor) ol {
  	font-weight: 800;
	font-size: 1.6em; 
}

table.dataTable thead .sorting_asc {
  text-align: left;
}

table.dataTable.row-border tbody th, table.dataTable.row-border tbody td, table.dataTable.display tbody th, table.dataTable.display tbody td {
  text-align: left;
  background: white !important;
  border: 0 !important;
}

.alphabet-group {
  font-weight: 900;
	font-size: 1.6em; 
  background: transparent;
}

tr.alphabet-group, tr.alphabet-group:hover {
  background: transparent !important;
}

table.dataTable.stripe tbody tr.odd, table.dataTable.display tbody tr.odd {
  background: transparent !important;
  border: 0 !important;
}

table.dataTable.display tbody tr.odd>.sorting_1, table.dataTable.order-column.stripe tbody tr.odd>.sorting_1 {
  background: white !important;
  border: 0 !important;
}
table.dataTable.display tbody tr.odd>.sorting_2, table.dataTable.order-column.stripe tbody tr.odd>.sorting_2 {
  background: white !important;
  border: 0 !important;
}

table.dataTable thead .sorting_asc {
  display: none;
}


/*Estilos filtros*/
.custom-filters {
  display: flex;
  grid-template-columns: auto auto;
}

.custom-filters > .container-filter1 {
  width: 80%;
  text-align: left;
  padding-left: 0px !important;
  padding: 10px;
}

.custom-filters > .container-filter2 {
  text-align: left;
  width: 80%;
  padding: 10px;
}
input[type="date"], input[type="email"], input[type="number"], input[type="password"], input[type="search"], input[type="tel"], input[type="text"], input[type="url"], select, textarea, .woocommerce .quantity input.qty, .wp-block-search input[type="search"], .dark input[type="email"], .dark input[type="password"], .dark input[type="tel"], .dark input[type="text"], .dark select, .dark textarea {
  width: 100%;
  height: 39px;
}

