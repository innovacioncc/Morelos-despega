<script type="text/javascript">
jQuery(document).ready(function(){
     var table = jQuery('#filterPersonalAcademico').DataTable ({
     lengthMenu: [
            [ 100, 200, 300 -1 ],
            [ 'Mostrar 100 Resultados.', 'Mostrar 200 Resultados.', 'Mostrar 300 Resultados.', 'Ver todos' ]
       ],
       
     
     
	 
      dom: '<"alphabet-container"A><"table-container"lfrtip>',

      responsive: true,

      //bFilter: false,
     language: {
     	url: '//cdn.datatables.net/plug-ins/1.11.3/i18n/es-mx.json',
     },
	fnInitComplete: function( oSettings ) {
     	jQuery('#example_filter').appendTo( jQuery('#search-filter-container') );
     },
     oLanguage: {
       lengthMenu: "Display _MENU_ records per page",
       sSearch: "Palabra clave <br>",
       oPaginate: {
            sFirst:   "Primero",
            sLast:   "Último",
            sNext:    "Siguiente",
            sPrevious: "Anterior",
        },
        sProcessing:    "Procesando...",
        sLengthMenu:    "_MENU_",
        sZeroRecords:   "No se encontraron resultados",
        sEmptyTable:    "Ningún dato disponible en esta tabla",
        sInfo:          "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
        sInfoEmpty:     "Mostrando registros del 0 al 0 de un total de 0 registros",
        sInfoFiltered:  "(filtrado de un total de _MAX_ registros)",
        sInfoPostFix:   "",
        sLoadingRecords: "Cargando...",
        oAria: {
            sSortAscending:  ": Activar para ordenar la columna de manera ascendente",
            sSortDescending: ": Activar para ordenar la columna de manera descendente"
        }
     }
   });
  
   jQuery('#working_area, #designation, #discipline, #area_de_adscripcion, #area_de_adscripcion_tecnica').change( function() {
     table.draw();
   });
  
  jQuery.fn.dataTable.ext.search.push(
      function( settings, data, dataIndex ) {
        // Input values
        var disciplineInput = $('#discipline').val();
        var workingAreaInput = $('#working_area').val();
        
        var designationInput = $('#designation').val();  
        
        
        // Data attributes
        var tr = $(table.row(dataIndex).node());
        var discipline  = tr.data('discipline');
        var workingArea = tr.data('working-area');
        
        var designation = tr.data('designation');
        
        
        if (disciplineInput !== '' && disciplineInput !== discipline) {
          return false;
        }
        
        
        
        
        if (workingAreaInput !== '' && workingAreaInput !== workingArea) {
          return false;
        }
        if (designationInput !== '' && designationInput !== designation) {
          return false;
        }
        return true;
      }
  );
  
    jQuery("div.dataTables_filter").appendTo(jQuery("#search-filter-container"));
  jQuery("#custom_filter").appendTo(jQuery("#search-filter-container"));
  
});





